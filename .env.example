# Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/insightiq

# Anthropic
ANTHROPIC_API_KEY=your-key-here
CLAUDE_MODEL=claude-sonnet-5

# LLM backend: "anthropic" or "ollama" (default) — chatbot.py and nl2sql.py
# use this to pick which model generates SQL/answers. Switch to "anthropic"
# once API credits are available.
LLM_BACKEND=ollama
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=llama3.2

# RAG
CHROMA_PERSIST_DIR=./rag/chroma_store
