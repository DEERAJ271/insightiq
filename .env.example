# Postgres
# 5432 is Postgres's standard default port. If your local Postgres
# install already has something else listening there, point this at
# whatever port your instance actually uses instead (e.g. 5544) — the
# exact port is a per-machine detail, not something a fresh clone needs
# to match.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/insightiq

# Anthropic
ANTHROPIC_API_KEY=your-key-here
CLAUDE_MODEL=claude-sonnet-5

# LLM backend: "anthropic" or "ollama" (default) — chatbot.py and nl2sql.py
# use this to pick which model generates SQL/answers. Switch to "anthropic"
# once API credits are available.
LLM_BACKEND=ollama
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=llama3.2

# RAG
CHROMA_PERSIST_DIR=./rag/chroma_store

# Snowflake (optional — only needed for etl/load_snowflake.py, i.e.
# `python etl/run_pipeline.py --target snowflake` or `--target both`).
# Untested against a live account; uncomment and fill in once you have one.
# SNOWFLAKE_ACCOUNT=xy12345.us-east-1
# SNOWFLAKE_USER=your-user
# SNOWFLAKE_PASSWORD=your-password
# SNOWFLAKE_WAREHOUSE=your-warehouse
# SNOWFLAKE_DATABASE=insightiq
# SNOWFLAKE_SCHEMA=public
# SNOWFLAKE_ROLE=your-role
